# Xcode
#
# gitignore contributors: remember to update Global/Xcode.gitignore, Objective-C.gitignore & Swift.gitignore

## User settings
xcuserdata/

## Compatibility with Xcode 8 and earlier (Objective-C or Swift)
*.xcscmblueprint
*.xccheckout

## Compatibility with Xcode 3 and earlier (Objective-C)
*.mode1v3
*.mode2v3
*.perspectivev3
*.pbxuser
!default.pbxuser
*.suuser
!default.suuser

## Product builds
build/
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

## Playgrounds
timeline.xctimeline
playground.xcworkspace

## Swift Package Manager
#
# Add this line if you want to avoid checking in source code from SPM dependencies.
# Package.swift
# Package.resolved
#
# Xcode 13+
.swiftpm/
.build/

## CocoaPods
#
# We recommend against adding the Pods directory to your .gitignore. However
# you should judge for yourself, the risks are explained in the following
# article: https://guides.cocoapods.org/using/using-cocoapods.html#should-i-check-the-pods-directory-into-source-control
#
# Pods/
#
# Add this line if you want to avoid checking in source code from CocoaPods dependencies.
# Podfile.lock
# .podenv

## Carthage
#
# Add this line if you want to avoid checking in source code from Carthage dependencies.
# Carthage/Checkouts

## Accio dependency management
Dependencies/
.accio/

## fastlane
#
# It is recommended to not store the screenshots in the git repo.
# Instead, use fastlane to re-generate the screenshots whenever they are needed.
# For more information about the recommended setup visit:
# https://docs.fastlane.tools/best-practices/source-control/#source-control

fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

## Code Injection
#
# After new Xcode update, files with "xcinject" extension are created.
# If you use UI testing, you should add this line to .gitignore file.
*.xcinject

## Mac
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

